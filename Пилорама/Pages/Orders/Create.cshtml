@page
@using Пилорама.Models;
@model Пилорама.Pages.Orders.CreateModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Order</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Order.Замовник" class="control-label"></label>
                <input asp-for="Order.Замовник" class="form-control" value=@User.Identity.Name />
                <span asp-validation-for="Order.Замовник" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Order.Назва" class="control-label"></label>
                <select asp-for="Order.Назва" class="form-control">
                
                    <option>Балка</option>
                    <option>Кроква</option>
                    <option>Лата</option>
                    <option>Дошка</option>

                </select>
                
                
            </div>
            <div class="form-group">
                <label asp-for="Order.Висота" class="control-label"></label>
                <input asp-for="Order.Висота" class="form-control" />
                <span asp-validation-for="Order.Висота" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Order.Ширина" class="control-label"></label>
                <input asp-for="Order.Ширина" class="form-control" />
                <span asp-validation-for="Order.Ширина" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Order.Довжина" class="control-label"></label>
                <input asp-for="Order.Довжина" class="form-control" />
                <span asp-validation-for="Order.Довжина" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Order.Кількість" class="control-label"></label>
                <input asp-for="Order.Кількість" class="form-control" />
                <span asp-validation-for="Order.Кількість" class="text-danger"></span>
            </div>
          @*   <div class="form-group">
                <label asp-for="Order.Об_єм" class="control-label"></label>
                <input asp-for="Order.Об_єм" class="form-control" />
                <span asp-validation-for="Order.Об_єм" class="text-danger"></span>
            </div> *@
            <div class="form-group">
                <label asp-for="Order.Ціна" class="control-label"></label>
                <input asp-for="Order.Ціна" class="form-control" value=7400 />
                <span asp-validation-for="Order.Ціна" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
