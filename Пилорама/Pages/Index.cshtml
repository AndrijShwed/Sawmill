@page
@model IndexModel
@{
    ViewData["Title"] = "Домашня сторінка";
}
<!DOCTYPE html>
<html>
<head>
  
    <style>
        body {
            margin: 0;
            padding: 0;
            overflow: hidden;
        }
         video {
             position: fixed;
             top: 50%;
             left: 50%;
             min-width: 100%;
             min-height: 100%;
             width: auto;
             height: auto;
             z-index: -1;
             transform: translateX(-50%) translateY(-50%);
         }

    </style>
    
</head>
<body>
  
    <video autoplay loop muted>
        <source src="/images/Порізка.mp4" type="video/mp4" />
    </video>
    <div class="text-center">
         
        @if (User.Identity.Name != "Admin@ukr.net" && User.Identity.IsAuthenticated)
        {
            <h1 class="display-4" style="font-style: unset; color:purple "><b>Вітаємо на сайті замовлень пиломатеріалів</b></h1>
            <div class="text-start">
                <a asp-page="./Orders/Index"><b style="font-size:xx-large">Створити замовлення</b></a>
            </div>
          @*   <div class="text-start">
                <a asp-page="./Numbers/Index"><b style="font-size:xx-large">Мої замовлення</b></a>
            </div> *@
        }
        else if(User.Identity.IsAuthenticated)
        {
            <h1 class="display-4" style="font-style: unset; color:purple "><b>Вітаємо на сайті замовлень пиломатеріалів</b></h1>
            <div class="text-start">
                <a asp-page="./Admin/Index"><b style="font-size:xx-large">Переглянути замовлення</b></a>
            </div>
            <div class="text-start">
                <a asp-page="./AdminNumbers/Index"><b style="font-size:xx-large">Опрацювати замовлення</b></a>
            </div>
            <div class="text-start">
                <a asp-page="./Prices/Index"><b style="font-size:xx-large">Встановити або змінити ціну</b></a>
            </div>
           
        }
    </div>
  

</body>
</html>