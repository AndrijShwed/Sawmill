      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
      <OriginalItemSpec>$([System.IO.Path]::GetFullPath($(MSBuildThisFileDirectory)..\staticwebassets\Пилорама.bundle.scp.css))</OriginalItemSpec>
    </StaticWebAsset>
  </ItemGroup>
</Project>